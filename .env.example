# JobTread API grant key — generate in JobTread under Settings > Grant Management
# WARNING: Grant keys expire after 3 months of inactivity. Rotate every 2 months.
JOBTREAD_GRANT_KEY=gt_your_grant_key_here

# Your JobTread organization ID — found in your JobTread account URL or settings
JOBTREAD_ORG_ID=org_your_org_id_here

# Shared API key your team includes in their Claude config (x-api-key header)
# Generate a strong random string: e.g. openssl rand -hex 32
MCP_API_KEY=mcp_your_secret_key_here
