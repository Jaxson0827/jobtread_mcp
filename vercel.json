{
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/mcp.ts": {
      "maxDuration": 30
    },
    "api/health.ts": {
      "maxDuration": 5
    }
  },
  "headers": [
    {
      "source": "/api/mcp",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, x-api-key, mcp-session-id" }
      ]
    },
    {
      "source": "/api/health",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache" }
      ]
    }
  ]
}
